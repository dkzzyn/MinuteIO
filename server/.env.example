# Porta do servidor (padrão: 3001)
PORT=3001

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://admin:123456@localhost:5432/meu_app?schema=public

# Auth (JWT)
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Ollama: URL onde o Ollama está rodando (local ou remoto)
OLLAMA_URL=http://localhost:11434

# Modelo do Ollama a usar (ex.: llama3.2, llama3.1, mistral, gemma3:4b)
OLLAMA_MODEL=llama3.2

# Whisper: modo de transcrição (local | api | mock)
# - mock: retorna transcrição fake (para testes sem Whisper instalado)
# - local: usa whisper CLI instalado no sistema (pip install openai-whisper)
# - api: usa API externa (OpenAI Whisper ou servidor próprio)
WHISPER_MODE=mock
WHISPER_MODEL=base

# Se WHISPER_MODE=api, configure:
# WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
# WHISPER_API_KEY=sk-...
