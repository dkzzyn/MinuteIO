# Porta do servidor (padrão: 3001)
PORT=3001

# Link mostrado em http://localhost:PORT/ (quando abrir a raiz do backend no navegador)
FRONTEND_URL=http://localhost:5173

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://admin:123456@localhost:5432/meu_app?schema=public

# Auth (JWT)
JWT_SECRET=change_me_in_production
# Em dev pode usar 30d para evitar "Token inválido ou expirado" com frequência
JWT_EXPIRES_IN=30d
# Refresh token armazenado na BD (dias)
JWT_REFRESH_EXPIRES_DAYS=30

# ---------------------------------------------------------------------------
# LLM: escolha UM modo
#
# A) Ollama direto (padrão) — não defina OPENAI_BASE_URL (ou comente).
# B) llama-swap — descomente OPENAI_BASE_URL e use alias do llama-swap-config.yaml
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_API_KEY=sk-local-no-key

# Com llama-swap + llama-swap-config.yaml da raiz do projeto, use alias:
# OLLAMA_MODEL=gpt-4
# Sem llama-swap, use o nome exato do modelo no Ollama:
OLLAMA_MODEL=gemma3:4b

# Retries/timeouts do cliente OpenAI (usado só se OPENAI_BASE_URL estiver definido)
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=500
LLM_TIMEOUT_MS=120000

# Ollama: URL onde o Ollama está rodando (modo direto; llama-swap também aponta aqui no yaml)
OLLAMA_URL=http://localhost:11434

# Whisper: modo de transcrição (local | api | mock)
WHISPER_MODE=mock
WHISPER_MODEL=base

# Se WHISPER_MODE=api, configure:
# WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
# WHISPER_API_KEY=sk-...
