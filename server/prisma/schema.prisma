generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  isActive     Boolean  @default(true)
  avatarUrl    String?
  posts        Post[]
  meetings     Meeting[]
  agents       Agent[]
  promptVersionsCreated PromptVersion[] @relation("PromptVersionCreatedBy")
  meetingAnalysesCreated MeetingAnalysis[] @relation("MeetingAnalysisCreatedBy")
  teamsOwned   Team[]
  teamInvitationsReceived TeamInvitation[] @relation("TeamInvitationInvitedUser")
  teamInvitationsSent     TeamInvitation[] @relation("TeamInvitationInvitedBy")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Agent {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  name      String
  slug      String
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  config    AgentConfig?

  @@unique([userId, slug])
  @@index([userId])
  @@map("agents")
}

model AgentConfig {
  id                  String   @id @default(cuid())
  agentId             String   @unique @map("agent_id")
  sentimentTone       String   @default("neutro") @map("sentiment_tone")
  salesAggressiveness String   @default("moderado") @map("sales_aggressiveness")
  objectionTips       Json?    @map("objection_tips")
  extraConfig         Json?    @map("extra_config")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

model Prompt {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String?
  promptText  String
  version     Int             @default(1)
  isActive    Boolean         @default(true)
  modelHint   String?
  versions    PromptVersion[]
  analyses    MeetingAnalysis[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([isActive])
  @@index([modelHint])
  @@map("prompts")
}

model PromptVersion {
  id          String   @id @default(cuid())
  promptId    String   @map("prompt_id")
  version     Int
  promptText  String   @map("prompt_text")
  description String?
  createdById String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  prompt      Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("PromptVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([promptId, version])
  @@index([promptId])
  @@index([createdById])
  @@map("prompt_versions")
}

model Team {
  id          String           @id @default(cuid())
  name        String
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invitations TeamInvitation[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([ownerId])
  @@map("teams")
}

enum TeamInvitationStatus {
  pending
  accepted
  rejected
}

model TeamInvitation {
  id            String               @id @default(cuid())
  teamId        String               @map("team_id")
  invitedUserId String               @map("invited_user_id")
  invitedById   String               @map("invited_by_id")
  status        TeamInvitationStatus @default(pending)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User @relation("TeamInvitationInvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("TeamInvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([invitedUserId])
  @@index([invitedById])
  @@unique([teamId, invitedUserId])
  @@map("team_invitations")
}

model Post {
  id          String    @id @default(cuid())
  userId      String
  title       String    @default("Sem título")
  content     String
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings    Meeting[]

  @@index([userId])
}

model Meeting {
  id            String          @id @default(cuid())
  userId        String
  postId        String?
  type          String
  title         String
  description   String?
  durationMinutes Int           @default(30)
  language      String          @default("pt-BR")
  pipelineStage String          @default("discovery")
  result        String          @default("Em andamento")
  participants  String[]
  winProbability Float          @default(0.5)
  objectionTypes String[]
  summary       String          @default("")
  datetimeStart DateTime
  datetimeEnd   DateTime?
  status        String
  recordingUrl  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post?           @relation(fields: [postId], references: [id], onDelete: SetNull)
  clips         MeetingClip[]
  insights      MeetingInsight[]
  analyses      MeetingAnalysis[]

  @@index([userId])
  @@index([postId])
  @@index([datetimeStart])
}

model MeetingAnalysis {
  id            String   @id @default(cuid())
  meetingId     String   @map("meeting_id")
  promptId      String   @map("prompt_id")
  createdById   String?  @map("created_by")
  modelUsed     String   @map("model_used")
  inputTextHash String?  @map("input_text_hash")
  outputText    String?  @map("output_text")
  createdAt     DateTime @default(now()) @map("created_at")
  meeting       Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Restrict)
  createdBy     User?    @relation("MeetingAnalysisCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([promptId])
  @@index([createdById])
  @@map("meeting_analyses")
}

model MeetingClip {
  id            String         @id @default(cuid())
  meetingId      String
  index         Int
  startTime     Int
  endTime       Int
  transcript    String
  processedByAi Boolean        @default(false)
  createdAt     DateTime       @default(now())
  meeting       Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  insights      MeetingInsight[]

  @@index([meetingId])
  @@unique([meetingId, index])
}

model MeetingInsight {
  id        String       @id @default(cuid())
  meetingId String
  clipId    String?
  type      String
  content   String
  createdAt DateTime     @default(now())
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  clip      MeetingClip? @relation(fields: [clipId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([clipId])
  @@index([type])
}
